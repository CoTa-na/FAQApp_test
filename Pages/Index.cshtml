@page
@model IndexModel
@{
    ViewData["Title"] = "FAQ一覧";
}

<section class="space-y-6">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="rounded-md border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800">@Model.ErrorMessage</div>
    }

    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
            <h1 class="text-3xl font-bold text-slate-900">社内FAQ</h1>
            <p class="text-sm text-slate-500">検索、編集、削除ができます。</p>
        </div>
        <a asp-page="/Create" class="inline-flex items-center justify-center rounded-md bg-emerald-600 px-4 py-2 font-medium text-white hover:bg-emerald-500">新規登録</a>
    </div>

    <form method="get" asp-page="/Index" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <label for="searchKeyword" class="mb-2 block text-sm font-medium text-slate-700">キーワード検索</label>
        <input id="searchKeyword"
               name="searchKeyword"
               value="@Model.SearchKeyword"
               class="w-full rounded-md border border-slate-300 px-3 py-2 text-slate-800 outline-none ring-emerald-500 focus:ring"
               placeholder="タイトルまたは本文で検索"
               hx-get="@Url.Page("/Index", "FaqList")"
               hx-target="#faq-list"
               hx-swap="outerHTML"
               hx-trigger="keyup changed delay:400ms" />
    </form>

    <partial name="_FaqList" model="Model.Faqs" view-data='new ViewDataDictionary(ViewData) { ["SearchKeyword"] = Model.SearchKeyword }' />
</section>

<div id="modal-container"></div>
