<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FAQApp_test</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FAQApp_test.styles.css" asp-append-version="true" />
    <script src="https://unpkg.com/htmx.org@2.0.7"></script>
</head>
<body class="bg-slate-100 text-slate-900">
    <header>
        <nav class="border-b border-slate-200 bg-white/90 backdrop-blur">
            <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
                <a class="text-xl font-bold tracking-tight text-emerald-700" asp-area="" asp-page="/Index">社内FAQ</a>
                <div class="flex gap-2">
                    <a class="rounded-md px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" asp-area="" asp-page="/Index">一覧</a>
                    <a class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500" asp-area="" asp-page="/Create">新規登録</a>
                </div>
            </div>
        </nav>
    </header>
    <div class="mx-auto max-w-5xl px-4 py-6">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-5xl px-4 py-4 text-sm text-slate-500">
            &copy; 2026 - FAQApp_test
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>