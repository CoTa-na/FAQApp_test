<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FAQApp_test</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FAQApp_test.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/htmx.org@2.0.7"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        (function () {
            var key = "color-theme";
            var root = document.documentElement;
            var stored = localStorage.getItem(key);
            var dark = stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches);
            root.classList.toggle("dark", dark);
        })();
    </script>
</head>
<body class="min-h-screen bg-slate-50 font-sans text-slate-800 transition-colors duration-300 dark:bg-slate-900 dark:text-slate-100">
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/80 backdrop-blur-md transition-colors duration-300 dark:border-slate-700 dark:bg-slate-800/80">
        <nav>
            <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4">
                <div class="flex items-center space-x-3">
                    <div class="rounded-lg bg-blue-600 p-2 text-white shadow-md shadow-blue-500/20">
                        <i data-lucide="help-circle" class="h-6 w-6"></i>
                    </div>
                    <div>
                        <a class="text-lg font-bold tracking-tight" asp-area="" asp-page="/Index">svn_Faq</a>
                        <p class="-mt-1 text-[10px] text-slate-400">社内ナレッジ共有システム</p>
                    </div>
                </div>
                <div class="flex items-center space-x-4">
                    <a class="rounded-md px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-700" asp-area="" asp-page="/Index">一覧</a>
                    <a class="rounded-md bg-emerald-600 px-3 py-2 text-sm font-medium text-white hover:bg-emerald-500" asp-area="" asp-page="/Create">新規登録</a>
                    <button id="theme-toggle" class="rounded-lg bg-slate-100 p-2 transition-colors hover:bg-slate-200 dark:bg-slate-700 dark:hover:bg-slate-600" title="テーマ切り替え" type="button">
                        <i id="theme-toggle-light-icon" data-lucide="sun" class="hidden h-5 w-5"></i>
                        <i id="theme-toggle-dark-icon" data-lucide="moon" class="h-5 w-5"></i>
                    </button>
                    <div class="hidden items-center space-x-2 border-l border-slate-200 pl-4 text-sm dark:border-slate-700 sm:flex">
                        <span class="text-slate-500 dark:text-slate-400">ログイン中:</span>
                        <span class="font-medium text-slate-700 dark:text-slate-200">svn (開発者)</span>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="mx-auto max-w-5xl px-4 py-6">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-5xl px-4 py-4 text-sm text-slate-500">
            &copy; 2026 - FAQApp_test
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var key = "color-theme";
            var root = document.documentElement;
            var btn = document.getElementById("theme-toggle");
            var lightIcon = document.getElementById("theme-toggle-light-icon");
            var darkIcon = document.getElementById("theme-toggle-dark-icon");

            function syncIcons() {
                var dark = root.classList.contains("dark");
                lightIcon.classList.toggle("hidden", !dark);
                darkIcon.classList.toggle("hidden", dark);
                if (window.lucide) {
                    window.lucide.createIcons();
                }
            }

            btn.addEventListener("click", function () {
                var dark = root.classList.contains("dark");
                root.classList.toggle("dark", !dark);
                localStorage.setItem(key, !dark ? "dark" : "light");
                syncIcons();
            });

            document.addEventListener("htmx:afterSwap", function () {
                if (window.lucide) {
                    window.lucide.createIcons();
                }
            });

            syncIcons();
            if (window.lucide) {
                window.lucide.createIcons();
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>